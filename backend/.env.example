# Copy this file to .env and fill in your values
# The backend reads all config from environment variables via ConfigService.

# Port the NestJS server listens on
PORT=3000

# MongoDB connection string
# Local:  mongodb://localhost:27017/shipfinex
# Docker: mongodb://mongodb:27017/shipfinex
MONGODB_URI=mongodb://localhost:27017/shipfinex

# Redis connection
# Local:  localhost / 6379
# Docker: redis / 6379
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ AMQP connection string
# Local:  amqp://localhost:5672
# Docker: amqp://rabbitmq:5672
RABBITMQ_URI=amqp://localhost:5672

# Binance WebSocket stream URL (used by IngestionService)
# Falls back to REST polling if WS is blocked by a firewall
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/!ticker@arr
